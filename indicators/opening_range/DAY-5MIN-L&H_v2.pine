//@version=5
indicator("DAY-5MIN-L&H_v2", overlay=true)

// ======================================================
// USE ONLY 1 MIN TIMEFRAME
// ======================================================
if timeframe.period != "1"
    runtime.error("Use this indicator only on 1 minute timeframe")

// ======================================================
// USER INPUTS
// ======================================================
marketHour = input.int(9, "Market Open Hour")
marketMinute = input.int(15, "Market Open Minute")
rangeCandles = input.int(1, "Opening Range Candle Count", minval=1, maxval=60)
showDays = input.int(30, "Show Past Days", minval=1, maxval=100)

// ======================================================
// VARIABLES
// ======================================================
var float rangeHigh = na
var float rangeLow = na
var float rangeAvg = na
var int startBar = na

// ======================================================
// DETECT START CANDLE
// ======================================================
isStartCandle = (hour == marketHour and minute == marketMinute)

// ======================================================
// RESET DAILY VALUES
// ======================================================
if isStartCandle
    rangeHigh := high
    rangeLow := low
    startBar := bar_index

// ======================================================
// COLLECT OPENING RANGE
// ======================================================
if not na(startBar) and (bar_index - startBar <= rangeCandles - 1)
    rangeHigh := math.max(rangeHigh, high)
    rangeLow := math.min(rangeLow, low)

// ======================================================
// SHOW ONLY LAST X DAYS
// ======================================================
dayMs = 86400000
showLine = time >= (timenow - (showDays * dayMs))

// ======================================================
// AFTER RANGE COMPLETE
// ======================================================
if not na(startBar) and (bar_index - startBar == rangeCandles - 1) and showLine

    rangeAvg := (rangeHigh + rangeLow) / 2

    // ==================================================
    // DIFFERENCE CALCULATION
    // ==================================================
    highAvgDiff = math.abs(rangeHigh - rangeAvg)
    lowAvgDiff = math.abs(rangeAvg - rangeLow)

    // ==================================================
    // ENTRY CALCULATION
    // ==================================================
    ceEntry = rangeHigh + highAvgDiff
    peEntry = rangeLow - lowAvgDiff

    sessionEnd = timestamp(year, month, dayofmonth, 15, 30)

    // ==================================================
    // HIGH LINE
    // ==================================================
    line.new(x1=time, y1=rangeHigh, x2=sessionEnd, y2=rangeHigh, xloc=xloc.bar_time, color=color.green, width=2)

    // ==================================================
    // LOW LINE
    // ==================================================
    line.new(x1=time, y1=rangeLow, x2=sessionEnd, y2=rangeLow, xloc=xloc.bar_time, color=color.red, width=2)

    // ==================================================
    // AVERAGE LINE
    // ==================================================
    line.new(x1=time, y1=rangeAvg, x2=sessionEnd, y2=rangeAvg, xloc=xloc.bar_time, color=color.blue, width=2, style=line.style_dashed)

    // ==================================================
    // CE ENTRY LINE
    // ==================================================
    line.new(x1=time, y1=ceEntry, x2=sessionEnd, y2=ceEntry, xloc=xloc.bar_time, color=color.lime, width=2, style=line.style_dotted)

    // ==================================================
    // PE ENTRY LINE
    // ==================================================
    line.new(x1=time, y1=peEntry, x2=sessionEnd, y2=peEntry, xloc=xloc.bar_time, color=color.orange, width=2, style=line.style_dotted)

    // ==================================================
    // LABELS
    // ==================================================
    label.new(x=time, y=rangeHigh, xloc=xloc.bar_time, text="HIGH : " + str.tostring(rangeHigh) + " | H-AVG : " + str.tostring(highAvgDiff), style=label.style_label_right, color=color.green, textcolor=color.white, size=size.small)

    label.new(x=time, y=rangeLow, xloc=xloc.bar_time, text="LOW : " + str.tostring(rangeLow) + " | AVG-L : " + str.tostring(lowAvgDiff), style=label.style_label_right, color=color.red, textcolor=color.white, size=size.small)

    label.new(x=time, y=rangeAvg, xloc=xloc.bar_time, text="AVG : " + str.tostring(rangeAvg), style=label.style_label_right, color=color.blue, textcolor=color.white, size=size.small)

    label.new(x=time, y=ceEntry, xloc=xloc.bar_time, text="CE ENTRY : " + str.tostring(ceEntry), style=label.style_label_right, color=color.lime, textcolor=color.black, size=size.small)

    label.new(x=time, y=peEntry, xloc=xloc.bar_time, text="PE ENTRY : " + str.tostring(peEntry), style=label.style_label_right, color=color.orange, textcolor=color.white, size=size.small)